{
  "name": "vibescan",
  "displayName": "vibescan — Security Scanner for Vibe-Coded Software",
  "description": "Security scanner for AI-generated code — SAST, DAST, exploit simulation, attack path analysis",
  "version": "0.0.1",
  "publisher": "vibescan",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "keywords": ["security", "scanner", "SAST", "DAST", "DevSecOps", "vibecoding", "ai-code"],
  "activationEvents": [
    "workspaceContains:.vibescan.yml",
    "onCommand:vibescan.scanWorkspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibescan.scanWorkspace",
        "title": "vibescan: Scan Workspace"
      },
      {
        "command": "vibescan.explainFinding",
        "title": "vibescan: Explain Finding"
      },
      {
        "command": "vibescan.fixFinding",
        "title": "vibescan: Fix with AI"
      }
    ],
    "configuration": {
      "title": "vibescan",
      "properties": {
        "vibescan.scanDepth": {
          "type": "string",
          "default": "quick",
          "enum": ["quick", "deep"],
          "description": "Default scan depth"
        },
        "vibescan.scanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan on file save"
        },
        "vibescan.scanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Scan workspace when opened"
        },
        "vibescan.minSeverity": {
          "type": "string",
          "default": "medium",
          "enum": ["info", "low", "medium", "high", "critical"],
          "description": "Minimum severity to display"
        },
        "vibescan.binaryPath": {
          "type": "string",
          "default": "vibescan",
          "description": "Path to the vibescan binary"
        },
        "vibescan.useLocalMode": {
          "type": "boolean",
          "default": true,
          "description": "Run scans locally without a server"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Armur-Ai/Armur-Code-Scanner"
  },
  "license": "MIT"
}
